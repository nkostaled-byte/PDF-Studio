{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account profile and subscription plan status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID matching auth.uid" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "plan": { "type": "string", "enum": ["free", "pro"], "description": "Subscription tier" },
        "subscriptionDate": { "type": "string", "format": "date-time", "description": "ISO timestamp when pro subscription was activated" },
        "paystackRef": { "type": "string", "description": "Paystack payment transaction reference" },
        "totalFilesProcessed": { "type": "number", "description": "Total files converted or merged" },
        "totalMbProcessed": { "type": "number", "description": "Total MBs converted or merged" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation ISO timestamp" }
      },
      "required": ["uid", "email", "plan", "createdAt"]
    },
    "ProcessingHistoryItem": {
      "title": "ProcessingHistoryItem",
      "description": "Log entry of a completed PDF processing or conversion tool operation",
      "type": "object",
      "properties": {
        "tool": { "type": "string", "enum": ["merge", "split", "compress", "img2pdf"], "description": "PDF tool used" },
        "fileName": { "type": "string", "description": "Name of processed file" },
        "originalSize": { "type": "number", "description": "Original file size in bytes" },
        "timestamp": { "type": "number", "description": "Unix timestamp in milliseconds" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO timestamp" }
      },
      "required": ["tool", "fileName", "originalSize", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile collection"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": { "$ref": "#/entities/ProcessingHistoryItem" },
      "description": "History of tool operations for a specific user"
    }
  }
}
